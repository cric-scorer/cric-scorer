{
	"expo": {
		"name": "CricScorer",
		"slug": "cricscorer",
		"scheme": "pk.alihamas.cricscorer",
		"userInterfaceStyle": "dark",
		"orientation": "default",
		"android": {
			"package": "pk.alihamas.cricscorer"
		},
		"ios": {
			"bundleIdentifier": "pk.alihamas.cricscorer"
		},
		"plugins": ["expo-font", "expo-router", "expo-secure-store"],
		"experiments": {
			"typedRoutes": true,
			"reactCompiler": true
		}
	}
}
