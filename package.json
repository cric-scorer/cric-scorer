{
	"name": "cric-scorer",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.2.2",
			"zod": "^4.1.13",
			"typescript": "^6",
			"convex": "^1.33.1",
			"better-auth": "~1.6.9",
			"@convex-dev/better-auth": "^0.12.2",
			"@tanstack/react-form": "^1.28.0",
			"@types/react-dom": "^19.2.3",
			"@better-auth/expo": "~1.6.9"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"check-types": "turbo check-types",
		"dev:native": "turbo -F native dev",
		"dev:web": "turbo -F web dev",
		"dev:server": "turbo -F @cric-scorer/backend dev",
		"dev:setup": "turbo -F @cric-scorer/backend dev:setup"
	},
	"dependencies": {
		"@cric-scorer/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@cric-scorer/config": "workspace:*",
		"@ianvs/prettier-plugin-sort-imports": "^4.7.1",
		"prettier": "^3.8.4",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"turbo": "^2.9.16",
		"typescript": "catalog:"
	},
	"packageManager": "bun@1.3.14"
}
